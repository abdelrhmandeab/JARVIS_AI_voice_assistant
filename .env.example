# Jarvis Environment Configuration (Production Baseline)
# Copy this file to .env and fill required secrets.

# Data directory — single home for logs, memory, index, state, KB, and vector
# artifacts (see core/config.py DATA_DIR). Individual JARVIS_*_FILE /
# JARVIS_*_DIR overrides below still take precedence over this default.
JARVIS_DATA_DIR=data

# Logging
# Minimum level shown in the console.
JARVIS_LOG_CONSOLE_LEVEL=INFO
# Minimum level retained in jarvis.log.
JARVIS_LOG_FILE_LEVEL=DEBUG
# Rotate jarvis.log after this many bytes.
JARVIS_LOG_ROTATE_MAX_BYTES=2000000
# Number of rotated jarvis.log backups to retain.
JARVIS_LOG_ROTATE_BACKUPS=3
# Emit per-stage and per-turn timing lines.
JARVIS_TIMING_LOG_ENABLED=true

# UI Bridge (WebSocket server for desktop UI)
JARVIS_UI_BRIDGE_ENABLED=true
JARVIS_UI_BRIDGE_PORT=9720
JARVIS_UI_BRIDGE_HOST=127.0.0.1

# Security
# Spoken PIN for sensitive commands (delete, close app, destructive system
# actions). Jarvis says "this needs your PIN", and the next utterance
# (digits or spoken number-words, EN/AR) is checked against this value.
JARVIS_SECOND_FACTOR_PIN=change_me
JARVIS_SECOND_FACTOR_PASSPHRASE=change_me
# pin: spoken-PIN confirmation (recommended). off: execute sensitive
# commands with no confirmation at all — not recommended.
JARVIS_SENSITIVE_CONFIRM_MODE=pin
# How long the PIN prompt stays open before it expires.
JARVIS_SENSITIVE_PIN_PENDING_TIMEOUT_SECONDS=30
JARVIS_SECOND_FACTOR_MAX_ATTEMPTS_PER_TOKEN=3
JARVIS_SECOND_FACTOR_LOCKOUT_SECONDS=120

# Phase 8 — timers
# Persist active timers to disk so they survive Jarvis restarts.
JARVIS_TIMER_PERSISTENCE_ENABLED=true
# Also open the Windows Clock app when setting an alarm (optional visual confirm).
JARVIS_TIMER_OPEN_CLOCK_APP=false
# Announce timer fire via the assistant TTS voice instead of a SAPI subprocess.
JARVIS_TIMER_FIRE_USE_TTS=true

# Phase 7 — screenshot + screen recording
# Directory for screenshots (default: ~/Pictures/Jarvis/Screenshots).
JARVIS_SCREENSHOT_DIR=~/Pictures/Jarvis/Screenshots
# Directory for screen recordings (default: ~/Videos/Jarvis/Recordings).
JARVIS_SCREENRECORD_DIR=~/Videos/Jarvis/Recordings
# Recording backend: auto (try ffmpeg, fall back to Game Bar) | ffmpeg | gamebar.
JARVIS_SCREENRECORD_BACKEND=auto
# Frames per second for ffmpeg recording.
JARVIS_SCREENRECORD_FPS=30

# Phase 6 — clipboard + window focus
# Max characters returned when reading clipboard aloud (longer content is truncated).
JARVIS_CLIPBOARD_READ_MAX_CHARS=280

# Email compose
# false (default): open empty compose window immediately.
# true: ask for to/subject/body in a two-turn dialogue before opening.
JARVIS_EMAIL_ASK_DETAILS=false
# true (default): prefer Outlook COM; false: go straight to Gmail web.
JARVIS_EMAIL_PREFER_OUTLOOK=true

# Phase 5 — startup app scan + refresh-on-miss
# Scan installed apps in the background at startup so new installs open by voice.
JARVIS_APP_SCAN_ON_STARTUP=true
# Cache TTL in hours before a forced rescan triggers on next open-app miss.
JARVIS_APP_CATALOG_TTL_HOURS=24
# Watch Start Menu folders for new installs via filesystem events (requires watchdog).
JARVIS_APP_WATCH_STARTMENU=true
# Trigger a background rescan when an app can't be found and catalog is stale.
JARVIS_APP_REFRESH_ON_MISS=true

# Phase 4 — Windows system toggles (Night Light, DND, Energy Saver, Live Captions)
# Method for night light toggle: registry (direct, instant) | uri (opens Settings).
JARVIS_TOGGLE_NIGHT_LIGHT_METHOD=registry
# Method for Do Not Disturb toggle: registry | uri.
JARVIS_TOGGLE_DND_METHOD=registry
# Method for energy saver toggle: powercfg (fastest) | registry | uri.
JARVIS_TOGGLE_ENERGY_SAVER_METHOD=powercfg
# Hotkey used to toggle Live Captions (Windows 11 documented shortcut).
JARVIS_LIVE_CAPTION_HOTKEY=win+ctrl+l

# Phase 3 — radio/connectivity toggles
# Backend for Wi-Fi/Bluetooth/Airplane: auto=WinRT-first then PowerShell.
# winrt: WinRT only (no admin needed on Win10/11).
# powershell: PowerShell only.
JARVIS_RADIO_BACKEND=auto
# When airplane mode is turned off, restore each radio to its pre-airplane state.
JARVIS_AIRPLANE_RESTORE_RADIOS=true

# Phase 3 — controls: verify real OS state before reporting success
# When true, every control (volume, radios, toggles) re-reads OS state after
# acting and only reports success if it actually changed.
JARVIS_CONTROLS_VERIFY_STATE=true
# When true, a verified failure gets an honest spoken message instead of a
# generic success template ("I couldn't change X — may need admin").
JARVIS_CONTROLS_HONEST_FAILURE=true
# On a verified failure, suggest running Jarvis as Administrator.
JARVIS_CONTROLS_ADMIN_HINT=true
# endpoint = real Windows system master volume (pycaw). app = legacy
# per-process waveOut volume — only for explicit opt-in, never a silent
# system-volume substitute.
JARVIS_VOLUME_BACKEND=endpoint

# Phase 2 — path-smart file commands + human-spoken locations
# Max search results spoken aloud before offering "want the rest?".
JARVIS_FILE_SPOKEN_RESULTS_MAX=3
# Speak friendly locations ("in Documents") instead of raw C:\Users\... paths.
JARVIS_FILE_HUMANIZE_PATHS=true
# Default folders searched when no location is given in a file command.
JARVIS_FILE_DEFAULT_SEARCH_ROOTS=Documents,Downloads,Desktop

# Phase 4 — file commands execute, don't narrate
# Search/find/list open Explorer directly instead of speaking a listing or
# asking "want me to open it?".
JARVIS_FILE_EXECUTE_NOT_NARRATE=true
# Match filenames by stem, ignoring extension ("open my cv" -> cv.pdf).
JARVIS_FILE_EXTENSION_OPTIONAL=true
# Open File Explorer for search/find/list results.
JARVIS_FILE_OPEN_IN_EXPLORER=true
# Never speak a raw filesystem path in any response.
JARVIS_FILE_SPEAK_PATHS=false

# LLM (Ollama)
# Model is auto-selected based on hardware (RAM/GPU). Override here to pin a specific model.
JARVIS_LLM_MODEL=qwen3:4b
JARVIS_LLM_AUTO_SELECT=true
# Context window ceilings; per-turn num_ctx is autosized from prompt size when enabled.
JARVIS_LLM_OLLAMA_NUM_CTX=4096
JARVIS_LLM_LIGHTWEIGHT_NUM_CTX=2048
JARVIS_LLM_CTX_AUTOSIZE=true
JARVIS_LLM_FEWSHOT_MIN=2
JARVIS_LLM_FEWSHOT_MAX=4
JARVIS_LLM_TIMEOUT_SECONDS=30
JARVIS_LLM_OLLAMA_BASE_URL=http://localhost:11434
JARVIS_LLM_OLLAMA_AUTOSTART=true
JARVIS_LLM_OLLAMA_EXECUTABLE=ollama
JARVIS_LLM_OLLAMA_AUTOSTART_TIMEOUT_SECONDS=25
JARVIS_LLM_RESPONSE_CACHE_ENABLED=true
JARVIS_LLM_RESPONSE_CACHE_TTL_SECONDS=600
JARVIS_LLM_RESPONSE_CACHE_TTL_FACTUAL_SECONDS=3600
JARVIS_LLM_RESPONSE_CACHE_TTL_OPINION_SECONDS=300
JARVIS_LLM_RESPONSE_CACHE_KEY_INCLUDES_PERSONA=true
JARVIS_LLM_RESPONSE_CACHE_MAX_SIZE=256
JARVIS_LLM_RESPONSE_CACHE_MAX_QUERY_WORDS=8
# Default reply language if STT and parsed language provide no English/Arabic lock.
JARVIS_LLM_DEFAULT_LANGUAGE=en
# Put a hard English/Egyptian-Arabic-only rule at the top of every LLM prompt.
JARVIS_LLM_LANG_PIN_ENABLED=true
JARVIS_LLM_TEMPERATURE=0.4
JARVIS_LLM_TOP_P=0.9
JARVIS_LLM_REPEAT_PENALTY=1.1
JARVIS_LLM_MAX_RESPONSE_TOKENS=160
JARVIS_LLM_STOP_TOKENS=\n\nUSER:,\nUSER:,</s>,<think>

# NLP / Routing
JARVIS_NLU_LLM_QUERY_EXTRACTION_ENABLED=false
JARVIS_NLU_PARSER_FASTPATH_ENABLED=true
JARVIS_NLU_PARSER_FASTPATH_CONFIDENCE_FLOOR=0.55
JARVIS_SEMANTIC_ROUTER_ENABLED=true
JARVIS_SEMANTIC_ROUTER_CONFIDENCE_THRESHOLD=0.75
# Phase 3 - semantic top-k + margin: best match must clear MIN_CONFIDENCE AND
# beat the runner-up by MIN_MARGIN, else the router defers instead of guessing.
# Phase 9 eval-derived note: tools/evaluate_nlu.py against the 143-case
# fixture set (tests/fixtures/nlu_eval_cases.jsonl) shows 0 unsafe executions
# and the near_tie category at 100% accuracy at these defaults — no
# evidence yet to justify changing them. The eval's 2 remaining
# margin_violations ("search for", "دور على") are keyword-NLP/parser filler-
# word bugs, not semantic-threshold issues; re-tune these values once the
# fixture set grows to include more true near-tie semantic cases.
JARVIS_SEMANTIC_MIN_CONFIDENCE=0.74
JARVIS_SEMANTIC_MIN_MARGIN=0.08
JARVIS_SEMANTIC_TOPK=3
# Phase 4 - code-switch shortcut: resolves mixed EN/AR verb+entity commands
# (e.g. "افتح Chrome", "زود volume") before the semantic embedding tier runs.
JARVIS_CODESWITCH_ROUTER_ENABLED=true
# Phase 5 - route verifier: logs the execute/clarify/confirm/llm decision +
# reason for every turn (route_decision / route_decision_reason in the
# structured route log). Does not change execution behavior by itself.
# FAST_COMMAND_MIN_CONFIDENCE is accepted by route_verifier.verify() but NOT
# yet applied as a gate — assess_intent_confidence's per-intent ceilings for
# common commands (OS_APP_OPEN/CLOSE=0.80, list_directory=0.78) sit below
# 0.88 by design, so a flat floor here would force clarification on clean,
# common commands. Needs eval-driven ceiling changes before this can be
# safely enforced (see core/route_verifier.py comments).
JARVIS_ROUTE_VERIFIER_ENABLED=true
JARVIS_FAST_COMMAND_MIN_CONFIDENCE=0.88
# Phase 6 - template-based clarification: missing-slot questions ("which app?")
# and semantic near-tie prompts ("did you mean X or Y?"). After
# CLARIFY_MAX_ROUNDS unresolved replies, gives up and falls through to the
# normal cascade instead of looping forever.
JARVIS_CLARIFY_FROM_TEMPLATES=true
JARVIS_CLARIFY_MAX_ROUNDS=2
# Phase 7 - structured LLM NLU fallback (OFF by default). Only fires when
# parser+codeswitch+semantic+keyword-NLP all missed AND Tier-4 tool-calling
# did NOT run this turn (never two LLM calls per turn) AND the text is
# long/multi-step. Output always passes route_verifier, never dispatched
# directly. Turn on only after the eval harness (Phase 8) shows it helps.
JARVIS_STRUCTURED_LLM_NLU_ENABLED=false
JARVIS_STRUCTURED_LLM_NLU_ONLY_ON_UNCERTAIN=true
JARVIS_STRUCTURED_LLM_NLU_TIMEOUT_SECONDS=4
# Phase 9 - routing telemetry. NLU_SHADOW_MARGIN logs (does not change
# behavior) when the old flat-threshold would have accepted a semantic route
# that Phase 3's margin scoring rejected as ambiguous. ROUTE_TIMING_LOG adds
# per-stage ms (normalize/parser/codeswitch/semantic/keyword_nlp/slot/verify/
# structured_llm) to the route_command_result structured log.
JARVIS_NLU_SHADOW_MARGIN=true
JARVIS_ROUTE_TIMING_LOG=true

# STT
# elevenlabs_scribe: ElevenLabs Scribe v2 primary for auto/Arabic, no forced language code
# hybrid_elevenlabs: legacy alias, resolves to elevenlabs_scribe
# faster_whisper: local whisper only (also used automatically when language=English)
JARVIS_STT_BACKEND=elevenlabs_scribe
# Realtime engine for English turns. auto/Arabic always use Scribe v2 (see JARVIS_STT_LANGUAGE_HINT).
JARVIS_STT_ENGLISH_ENGINE=faster_whisper
# If the Scribe cloud call fails (network/quota) on a non-English turn, fall back to local whisper.
JARVIS_STT_CLOUD_FAILURE_FALLBACK_TO_LOCAL=true
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
#main api key
#ELEVENLABS_API_KEY=sk_c25e459fb506abdcbc7378dcfce83ccdc5b6ce568d41f402
#backup api key
ELEVENLABS_API_KEY=sk_a806d7cc9ad085586012a0083ca70e8a2a4fd0628dfcd27e
JARVIS_STT_ELEVENLABS_ENABLED=true
JARVIS_STT_ELEVENLABS_MODEL=scribe_v2
JARVIS_STT_ELEVENLABS_CONNECT_TIMEOUT_SECONDS=2.0
JARVIS_STT_ELEVENLABS_READ_TIMEOUT_SECONDS=15.0
JARVIS_STT_ELEVENLABS_HTTP2=true
JARVIS_STT_ELEVENLABS_COOLDOWN_SECONDS=1800
JARVIS_STT_MAX_AUDIO_SECONDS=12
JARVIS_STT_ELEVENLABS_WEAK_TEXT_MIN_CHARS=5
# Lock STT to English + Egyptian Arabic only; "auto" is resolved before Whisper decode.
JARVIS_STT_LANGUAGE_LOCK=true
JARVIS_STT_LANGUAGE_HINT=auto
# Reject transcripts that drift into unsupported languages/scripts.
JARVIS_STT_FORBID_OTHER_LANGUAGES=true
# Dominance floor only applies to monolingual transcripts; mixed EN/AR text
# always bypasses this gate (see _looks_mixed in audio/stt.py). Lowered from
# 0.70 so a borderline-monolingual transcript isn't rejected too eagerly.
JARVIS_STT_VALIDATION_DOMINANT_SCRIPT_MIN=0.55
# Whisper primers for pinned-language decoding.
JARVIS_STT_AR_INITIAL_PROMPT=محادثة بالعامية المصرية فيها كلمات إنجليزي زي Chrome و Spotify و WiFi:
JARVIS_STT_EN_INITIAL_PROMPT=
# Retry once with the opposite pinned language if validation fails. Skipped
# automatically when the primary transcript was already mixed EN/AR — see
# _looks_mixed guards around the retry call sites in audio/stt.py.
JARVIS_STT_RETRY_OPPOSITE_LANGUAGE=true
# Mixed EN/AR speech (app names, tech nouns) is the normal case — keep this on.
JARVIS_STT_MIXED_LANGUAGE_MODE=true
# always: force language_code on every ElevenLabs call. auto (default): omit
# language_code when streaming text already looks code-switched, letting
# Scribe v2 auto-detect the mix instead of being biased toward one script.
JARVIS_STT_ELEVENLABS_SEND_LANGUAGE_CODE=auto
# Short transcripts below this confidence are treated as noise (empty), not hallucinated text.
JARVIS_STT_MIN_CONFIDENCE=0.35
JARVIS_STT_MIN_CONFIDENCE_SHORT_WORDS=3
JARVIS_WHISPER_MODEL=auto
JARVIS_WHISPER_COMPUTE_TYPE=auto
JARVIS_WHISPER_DEVICE=auto
JARVIS_STT_BEAM_SIZE_SHORT=1
JARVIS_STT_BEAM_SIZE_LONG=5
JARVIS_STT_BEAM_SIZE_SHORT_THRESHOLD_SECONDS=2.0
# Reject non-speech a bit harder to cut hallucination on silence/noise.
JARVIS_STT_NO_SPEECH_THRESHOLD=0.60
# Drop near-silent buffers earlier, before they reach decode.
JARVIS_STT_MIN_AUDIO_RMS=0.008
# English-only local whisper model (auto scales small.en/medium.en with hardware
# via core/hardware_detect.py; English-only models beat same-size multilingual ones).
JARVIS_STT_ENGLISH_WHISPER_MODEL=auto
JARVIS_STT_ENGLISH_BEAM_SIZE=5

# Audio capture
# Hard ceiling for a command recording.
JARVIS_MAX_RECORD_DURATION=5
JARVIS_VAD_ENERGY_THRESHOLD=0.015
# Snappier cutoff — short OS commands don't need 1.5s of grace.
JARVIS_VAD_COMMAND_SILENCE_SECONDS=0.35
# Cap adaptive silence ramp growth.
JARVIS_VAD_CHAT_SILENCE_SECONDS=0.90
JARVIS_VAD_SILENCE_SECONDS=0.50
JARVIS_VAD_MIN_SPEECH_SECONDS=0.30
# Give up sooner if no speech starts.
JARVIS_VAD_START_TIMEOUT_SECONDS=2.0
JARVIS_SPEECH_GUARD_SKIP_NON_RESPONSIVE_PROFILES=false

# TTS
# hybrid: ElevenLabs-first for English + Arabic, Edge-TTS fallback when offline/unavailable
JARVIS_TTS_BACKEND=hybrid
JARVIS_TTS_QUALITY_MODE=natural

# Voice profile — one switch picks ElevenLabs voice + edge-tts EN/AR pair together.
# Built-in profiles: jarvis_male_classic | jarvis_female_warm | jarvis_male_calm | custom
JARVIS_TTS_VOICE_PROFILE=jarvis_male_classic
# Custom-profile overrides (used when profile=custom, or to override any built-in field):
JARVIS_TTS_ELEVENLABS_VOICE_ID=
JARVIS_TTS_EDGE_VOICE_EN=
JARVIS_TTS_EDGE_VOICE_AR=
JARVIS_TTS_EDGE_VOICE_EN_FALLBACKS=
JARVIS_TTS_EDGE_VOICE_AR_FALLBACKS=

# Legacy env keys (JARVIS_TTS_EDGE_VOICE, JARVIS_TTS_EDGE_ARABIC_VOICE, etc.)
# still work via the alias bridge in core/tts_voices.py but are no longer
# listed here.  New installs should use the voice profile above.

# Sentence-level streaming playback — start speaking before the whole reply is synthesized.
JARVIS_TTS_SENTENCE_STREAMING_ENABLED=true
JARVIS_TTS_SENTENCE_SYNTH_WORKERS=2
JARVIS_TTS_SENTENCE_FIRST_FLUSH_MIN_CHARS=18
JARVIS_TTS_SENTENCE_GAP_MS=120
JARVIS_TTS_PARAGRAPH_GAP_MS=300

# Prosody tuning — ElevenLabs voice settings from profile; edge-tts SSML micro-breaks.
JARVIS_TTS_SSML_BREAKS_ENABLED=true
JARVIS_TTS_SSML_BREAK_AFTER_COMMA_MS=80
JARVIS_TTS_SSML_BREAK_AFTER_PERIOD_MS=180
JARVIS_TTS_SSML_BREAK_AFTER_QUESTION_MS=220
JARVIS_TTS_SSML_BREAK_AFTER_AR_SEMICOLON_MS=120
# ElevenLabs model: eleven_multilingual_v2 (bilingual) or eleven_turbo_v2_5 (faster, less natural).
JARVIS_TTS_ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Prosody polisher — deterministic text cleanup before TTS (no LLM).
JARVIS_TTS_PROSODY_POLISHER_ENABLED=true
JARVIS_TTS_EGY_DISCOURSE_COMMA_ENABLED=true
JARVIS_TTS_FORMAL_CONNECTOR_REWRITE_ENABLED=true
JARVIS_TTS_PUNCTUATION_DEDUP_ENABLED=true

# Slim EGY rewriter — skip rewrite when text is already Egyptian Arabic.
JARVIS_TTS_EGY_REWRITE_AGGRESSIVE=false
JARVIS_TTS_EGY_REWRITE_SKIP_THRESHOLD=3

JARVIS_TTS_ELEVENLABS_ARABIC_ENABLED=true
JARVIS_TTS_ELEVENLABS_TIMEOUT_SECONDS=15
JARVIS_TTS_EDGE_MIXED_SCRIPT_CHUNKING=true
JARVIS_TTS_EDGE_MIXED_SCRIPT_MAX_CHUNKS=6
JARVIS_TTS_EDGE_MIXED_SCRIPT_MAX_TEXT_LENGTH=180
JARVIS_TTS_ARABIC_SPOKEN_DIALECT=egyptian
JARVIS_TTS_EGYPTIAN_COLLOQUIAL_REWRITE=true
JARVIS_TTS_PREWARM_ENABLED=true
JARVIS_STARTUP_PARSER_NLP_PREWARM_ENABLED=true
# Load non-critical models after listening begins.
JARVIS_STARTUP_BACKGROUND_PREWARM_ENABLED=true
# Force semantic-router loading onto the startup critical path.
JARVIS_PREWARM_SEMANTIC_ROUTER_BLOCKING=false
# Force Ollama/model warmup onto the startup critical path.
JARVIS_PREWARM_LLM_BLOCKING=false
# Run startup doctor diagnostics outside the critical path.
JARVIS_DOCTOR_STARTUP_ASYNC=true

# Identity / self-introduction
# Response mode: pool (instant, varied pool) or llm (one-shot generation at higher temperature).
JARVIS_IDENTITY_MODE=pool
# Avoid repeating the same intro twice in a row.
JARVIS_IDENTITY_AVOID_REPEAT=true
# Temperature for LLM mode only (0.0-2.0, higher = more varied).
JARVIS_IDENTITY_LLM_TEMPERATURE=0.9

# Note-taking
# Directory alias where notes are saved (Desktop, Documents, or an absolute path).
JARVIS_NOTE_DIR=Desktop
# Base name for auto-numbered notes ("note 1.txt", "note 2.txt", …).
JARVIS_NOTE_BASENAME=note
# Seconds to wait for the user to dictate the note body before abandoning.
JARVIS_NOTE_PENDING_TIMEOUT_SECONDS=30

# Phase 4 -- Screen describe
# "window" (default): reads window titles via Win32 API, no image capture.
# "vision": captures a screenshot and sends it to the vision LLM.
JARVIS_SCREEN_DESCRIBE_MODE=window
# Maximum number of open apps to mention in the screen description.
JARVIS_SCREEN_DESCRIBE_MAX_APPS=8

# Wake word
# One bilingual custom model handles all English and Egyptian-Arabic phrases.
JARVIS_WAKE_WORD_UNIFIED_ONNX_PATH=models/jarvis_unified/jarvis_unified.onnx
JARVIS_WAKE_WORD_THRESHOLD=0.45
JARVIS_WAKE_WORD_CONFIRM_FRAMES=1
JARVIS_WAKE_WORD_DETECTION_COOLDOWN_SECONDS=1.5
JARVIS_WAKE_WORD_CHUNK_SIZE=1280
JARVIS_WAKE_WORD_INPUT_DEVICE=
JARVIS_WAKE_WORD_AUDIO_GAIN=1.4
JARVIS_WAKE_WORD_MIN_RMS=0.015
JARVIS_WAKE_WORD_SCORE_DEBUG=false
JARVIS_WAKE_WORD_SCORE_DEBUG_INTERVAL_SECONDS=10
# Two-level gate: the EMA-smoothed score must clear THRESHOLD, and at least
# one raw frame in the confirm window must also clear PEAK_THRESHOLD.
JARVIS_WAKE_WORD_PEAK_THRESHOLD=0.60
JARVIS_WAKE_WORD_EMA_WINDOW=3
# Pause after a wake-word fire before the recording mic opens, so the tail of
# "Jarvis"/"جارفيس" is never captured as the start of the command.
JARVIS_WAKE_WORD_RECORD_START_DELAY_MS=150
# Folder where wake activations are saved for training
JARVIS_WAKE_WORD_USER_SAMPLES_DIR=data/wake_samples/user_positive
# Optional speaker label used to separate each user's pronunciations
JARVIS_WAKE_WORD_SPEAKER_ID=
# Legacy keys (ignored if set): JARVIS_WAKE_WORD, JARVIS_WAKE_WORD_AR_*,
# JARVIS_WAKE_WORD_MODE, JARVIS_WAKE_MODE, JARVIS_WAKE_WORD_EN_THRESHOLD,
# JARVIS_WAKE_WORD_AR_THRESHOLD.

# Wake-word interrupt UX — audible feedback tones
# Soft bleep when interrupt fires (wake word during TTS/LLM)
JARVIS_WAKE_INTERRUPT_ACK_SOUND=true
JARVIS_WAKE_INTERRUPT_ACK_FREQ_HZ=880
JARVIS_WAKE_INTERRUPT_ACK_DURATION_MS=100
# Quieter tone when interrupt is blocked (during command execution). Off by default.
JARVIS_WAKE_INTERRUPT_BLOCKED_TONE_ENABLED=false
JARVIS_WAKE_INTERRUPT_BLOCKED_TONE_FREQ_HZ=220
JARVIS_WAKE_INTERRUPT_BLOCKED_TONE_DURATION_MS=80

# Adaptive wake-word retraining: learns from confirmed detections
JARVIS_ADAPTIVE_WAKE_ENABLED=true
# Minimum confirmed detections before a retrain is triggered
JARVIS_ADAPTIVE_WAKE_MIN_CONFIRMED=15
# How often (seconds) the daemon checks whether to retrain
JARVIS_ADAPTIVE_WAKE_RETRAIN_INTERVAL_SECONDS=3600
# Training epochs per adaptive retrain cycle
JARVIS_ADAPTIVE_WAKE_EPOCHS=10
# Minimum validation accuracy to accept a retrained model
JARVIS_ADAPTIVE_WAKE_MIN_VAL_ACC=0.95
# Directories for confirmed true-positive / false-positive samples
JARVIS_ADAPTIVE_WAKE_CONFIRMED_DIR=data/wake_samples/confirmed_positive
JARVIS_ADAPTIVE_WAKE_FALSE_POSITIVE_DIR=data/wake_samples/confirmed_negative

# Weather (Open-Meteo — free, no API key)
JARVIS_WEATHER_LATITUDE=30.04
JARVIS_WEATHER_LONGITUDE=31.24
JARVIS_WEATHER_CITY=Cairo

# Web search (DuckDuckGo — free, no API key)
JARVIS_WEB_SEARCH_ENABLED=true
JARVIS_WEB_SEARCH_MAX_RESULTS=3
JARVIS_LIVE_DATA_FORCE_QUESTIONS=false

# Shell integration
JARVIS_POWERSHELL_EXECUTABLE=powershell

# Advanced runtime tuning (defaults shown; override only when needed)
JARVIS_APP_AVAILABLE_BONUS=0.03
JARVIS_APP_RECENT_BONUS_SECONDS=1800
JARVIS_APP_RUNNING_BONUS_CLOSE=0.16
JARVIS_APP_RUNNING_BONUS_OPEN=0.04
JARVIS_APP_USAGE_BOOST_CAP=0.12
JARVIS_APP_USAGE_BOOST_PER_HIT=0.02
JARVIS_CLARIFICATION_CORRECTION_WINDOW_SECONDS=45
JARVIS_CLARIFICATION_FALLBACK_AFTER_MISSES=2
JARVIS_CLARIFICATION_PREFERENCE_HALF_LIFE_SECONDS=1209600
JARVIS_CLARIFICATION_PREFERENCE_MIN_SCORE=0.34
JARVIS_CLARIFICATION_PREF_MAX_AGE_SECONDS=1209600
JARVIS_CLAUDE_DEFAULT_MODEL=claude-haiku-4-5
