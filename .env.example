JARVIS_MEMORY_BACKEND=sqlite
# Overrides for individual memory files (default: <data>/memory/jarvis_memory.db|json).
JARVIS_MEMORY_DB_FILE=
JARVIS_MEMORY_FILE=
JARVIS_MEMORY_LANGUAGE_HISTORY_PERSIST_LIMIT=3
JARVIS_MEMORY_MAX_CONTEXT_CHARS=900
JARVIS_MEMORY_PERSIST_LANGUAGE_HISTORY=true
# Phase 2 — MemoryManager fast (RAM-only) vs LLM context split.
JARVIS_MEMORY_FAST_CONTEXT_ENABLED=true
JARVIS_MEMORY_LLM_CONTEXT_ENABLED=true
JARVIS_MEMORY_SHORT_TERM_TURNS=6
# Phase 4 — pending-task TTL for multi-turn slot filling (email/calendar/etc).
JARVIS_MEMORY_PENDING_TASK_TTL_SECONDS=180
# Phase 5 — long-term user preferences (default browser, city, etc.)
JARVIS_MEMORY_PREFERENCES_ENABLED=true
# Phase 6 — command-usage memory (habit-aware resolution).
JARVIS_MEMORY_COMMAND_USAGE_ENABLED=true
JARVIS_MEMORY_COMMAND_USAGE_MAX_ROWS=100
# Phase 7 — vector recall gating (slow-path only) + async embedding writes.
JARVIS_MEMORY_VECTOR_RECALL_ENABLED=true
JARVIS_MEMORY_VECTOR_RECALL_MIN_QUERY_WORDS=4
JARVIS_MEMORY_VECTOR_RECALL_MAX_RESULTS=3
JARVIS_MEMORY_VECTOR_WRITE_ASYNC=true
# Phase 8 — single MEMORY CONTEXT block in LLM-bound prompts only.
JARVIS_MEMORY_PROMPT_BLOCK_ENABLED=true
# Phase 9 — reference-resolver shadow rollout + per-turn memory timing log.
JARVIS_MEMORY_REF_SHADOW=false
JARVIS_MEMORY_TIMING_LOG=true
# Vector memory (Chroma) directory override (default: <data>/vectors).
JARVIS_VECTOR_MEMORY_DIR=
# Search index / state DB / log file overrides (defaults under <data>/).
